# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb+srv://jbccdevuser:12345pak@jbccdev.mongodb.net/db
DB_NAME=jbccdev

# JWT Configuration
JWT_SECRET=jobcallcenter_secret_key
JWT_EXPIRES_IN=7d

# NextAuth Configuration (for frontend authentication)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=jobcallcenter_nextauth_secret_key
AUTH_REDIRECT_URL=http://localhost:3000/auth/callback

# OAuth Providers (for social login)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
FACEBOOK_CLIENT_ID=your_facebook_client_id
FACEBOOK_CLIENT_SECRET=your_facebook_client_secret
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
AWS_S3_BUCKET=jobcallcenter1
AWS_S3_BASE_URL=https://jobcallcenter1.s3.eu-west-1.amazonaws.com

# Email Configuration (SendGrid)
SENDGRID_API_KEY=SG.sample_key.sample_secret_key_replace_with_actual_key
EMAIL_FROM=noreply@jobcallcenter.ma
EMAIL_FROM_NAME=JobCallCenter.ma

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# WhatsApp Business API (for chat widget)
WHATSAPP_BUSINESS_ID=sample_id
WHATSAPP_API_TOKEN=sample_token
WHATSAPP_PHONE_NUMBER=+212600000000
